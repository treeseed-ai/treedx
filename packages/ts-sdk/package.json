{
  "name": "@treeseed/treedx",
  "version": "0.2.25",
  "description": "Generic TypeScript SDK for TreeDX.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/treeseed-ai/treedx.git",
    "directory": "packages/ts-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "types": "./dist/treedx/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/treedx/index.d.ts",
      "default": "./dist/treedx/index.js"
    },
    "./treedx": {
      "types": "./dist/treedx/index.d.ts",
      "default": "./dist/treedx/index.js"
    },
    "./treedx/client": {
      "types": "./dist/treedx/client/index.d.ts",
      "default": "./dist/treedx/client/index.js"
    },
    "./treedx/types": {
      "types": "./dist/treedx/types/index.d.ts",
      "default": "./dist/treedx/types/index.js"
    },
    "./treedx/adapters": {
      "types": "./dist/treedx/adapters/index.d.ts",
      "default": "./dist/treedx/adapters/index.js"
    },
    "./treedx/conformance": {
      "types": "./dist/treedx/conformance/index.d.ts",
      "default": "./dist/treedx/conformance/index.js"
    }
  },
  "files": [
    "README.md",
    "dist",
    "sdk-manifest.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "test:treedx-unit": "vitest run --config ./vitest.config.ts test/unit test/adapters test/generated",
    "test:treedx-conformance": "vitest run --config ./vitest.config.ts test/conformance",
    "test:treedx-integration": "vitest run --config ./vitest.config.ts test/integration",
    "treedx:generate": "tsx scripts/generate-treedx-openapi-types.ts",
    "treedx:check-generated": "tsx scripts/check-treedx-generated-types.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "yaml": "^2.8.1",
    "tsx": "^4.21.0"
  }
}
